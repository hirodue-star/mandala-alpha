# ─────────────────────────────────────────────────────────
# マンダラα 環境変数テンプレート
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env
# ─────────────────────────────────────────────────────────

# Slack Incoming Webhook URL
# 設定方法: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Notion API Token (Internal Integration)
# 設定方法: https://www.notion.so/my-integrations
NOTION_API_TOKEN=

# Notion Database ID (開発ログDB)
# DBページURLの末尾32文字
NOTION_DATABASE_ID=

# Anthropic API Key (Claude連携用)
ANTHROPIC_API_KEY=

# OpenAI API Key (Whisper音声入力用)
OPENAI_API_KEY=
